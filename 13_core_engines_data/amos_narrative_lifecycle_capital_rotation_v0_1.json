{
  "version": "AMOS Narrative Lifecycle & Capital Rotation Engine v0.1",
  "purpose": "Model how narratives are born, validated, funded, crowded, exhausted, and reset; distinguish expansion from rotation.",
  "core_principles": [
    "Narrative is not truth; it is what the market is willing to price.",
    "Capital flow validates narrative strength more than social media heat.",
    "New theme strength does not automatically mean old theme death.",
    "The key distinction is expansion vs rotation vs late-cycle chase.",
    "State-level strategic narratives usually have longer duration than meme narratives."
  ],
  "narrative_lifecycle": {
    "stage_0_dormant": {
      "description": "Theme exists but market does not care yet.",
      "signals": [
        "low volume",
        "few institutional mentions",
        "no relative strength",
        "companies not reacting to related news"
      ],
      "action": "research only"
    },
    "stage_1_early_signal": {
      "description": "First signs of market attention.",
      "signals": [
        "isolated stock strength",
        "policy/news catalyst",
        "insider/analyst language changes",
        "relative strength vs market begins"
      ],
      "action": "watchlist / small research position"
    },
    "stage_2_institutional_recognition": {
      "description": "Serious capital begins to recognize the theme.",
      "signals": [
        "large-cap leaders move",
        "analyst upgrades",
        "earnings call language confirms",
        "ETF/sector strength",
        "volume expansion"
      ],
      "action": "build core candidates"
    },
    "stage_3_capital_expansion": {
      "description": "Capital spreads from leaders into second-line names.",
      "signals": [
        "leadership chain forms",
        "second-line stocks outperform",
        "sector breadth improves",
        "options activity increases"
      ],
      "action": "attack leaders / build high-quality beta"
    },
    "stage_4_mainstream_fomo": {
      "description": "Theme becomes obvious and broadly discussed.",
      "signals": [
        "retail attention rises",
        "YouTube/X/social heat",
        "tail names begin moving",
        "valuation stretch grows"
      ],
      "action": "hold winners, avoid late chase"
    },
    "stage_5_crowded_consensus": {
      "description": "Everyone agrees; risk-reward deteriorates.",
      "signals": [
        "extreme call activity",
        "valuation no longer matters",
        "weak stocks fly",
        "good news stops working",
        "RSI/Gann resistance"
      ],
      "action": "trim / sell calls / protect profit"
    },
    "stage_6_exhaustion": {
      "description": "Narrative still sounds strong but price behavior weakens.",
      "signals": [
        "leaders fail to make highs",
        "second-line breaks first",
        "volume divergence",
        "AVWAP breaks",
        "failed breakouts"
      ],
      "action": "de-risk / exit weak names"
    },
    "stage_7_reset": {
      "description": "Theme survives but valuation and holders reset.",
      "signals": [
        "forced selling",
        "media turns negative",
        "RSI oversold",
        "panic maturity begins",
        "fundamentals remain intact"
      ],
      "action": "prepare panic-buy candidates"
    }
  },
  "capital_rotation_types": {
    "expansion": {
      "definition": "New themes rise while old core leadership remains healthy.",
      "example": "AI Infra remains strong while Space/Quantum/Power begin rising.",
      "portfolio_implication": "Do not sell core leaders blindly; add carefully to new verified branches."
    },
    "rotation": {
      "definition": "Capital leaves old leadership and enters new leadership.",
      "signals": [
        "old leaders underperform",
        "new leaders outperform",
        "relative strength flips",
        "volume migrates"
      ],
      "portfolio_implication": "Trim weakening old branch and migrate to new confirmed leaders."
    },
    "defensive_shift": {
      "definition": "Capital leaves high beta and moves to defensives/cash/bonds/gold.",
      "signals": [
        "breadth weakens",
        "VIX rises",
        "credit stress",
        "utilities/healthcare outperform"
      ],
      "portfolio_implication": "Reduce beta, protect gains."
    },
    "late_cycle_chase": {
      "definition": "Money chases low-quality tail names after leaders already ran.",
      "signals": [
        "junk stocks move",
        "social FOMO",
        "options mania",
        "leaders flatten"
      ],
      "portfolio_implication": "Avoid chase; prepare trim."
    }
  },
