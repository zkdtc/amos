  "scoring_model_v0": {
    "narrative_strength_score": {
      "components": {
        "leader_relative_strength": 0.25,
        "capital_flow_confirmation": 0.25,
        "earnings_or_policy_validation": 0.2,
        "breadth_within_theme": 0.15,
        "quality_of_attention": 0.15
      }
    },
    "maturity_score": {
      "components": {
        "valuation_stretch": 0.2,
        "retail_attention": 0.2,
        "tail_name_participation": 0.2,
        "options_mania": 0.2,
        "price_response_to_good_news_fading": 0.2
      }
    },
    "failure_risk_score": {
      "components": {
        "leader_breakdown": 0.25,
        "capex_or_fundamental_disconfirmation": 0.25,
        "macro_regime_shift": 0.2,
        "gamma_negative_shift": 0.15,
        "crowding_extreme": 0.15
      }
    }
  },
  "agent_rules": [
    "Narrative AI must not create new modules for every new theme. It must map new themes into lifecycle stages.",
    "Capital Flow AI must classify new strength as expansion, rotation, defensive shift, or late-cycle chase.",
    "Risk AI must flag late-cycle chase when weak tail names outperform leaders.",
    "Decision AI must distinguish 'right narrative, wrong timing' from 'dead narrative'."
  ]
}