{
  "version": "AMOS Gann Calculator Module v0.1",
  "created": "2026-05-24",
  "purpose": "Independent calculator for Gann Square of Nine price levels, time windows, and price-time resonance preparation.",
  "core_principles": [
    "Gann is a timing and level research tool, not a standalone trading signal.",
    "Anchor quality determines calculation quality.",
    "Price levels must be treated as zones, not exact magic points.",
    "Gann signal becomes actionable only when confirmed by price action, AVWAP, RSI, volume, options/gamma and event context.",
    "Multiple anchors are preferred; dense clusters matter more than isolated levels."
  ],
  "square_of_nine_formula": {
    "formula": "P_target = (sqrt(P_base) ± angle/180)^2",
    "default_angles": [
      45,
      90,
      180,
      270,
      360,
      720
    ],
    "default_tolerance_pct": 0.5
  },
  "time_window_defaults": {
    "short_term_days": [
      7,
      14,
      21,
      34,
      45,
      55
    ],
    "medium_term_days": [
      60,
      90,
      144,
      180
    ],
    "long_term_days": [
      360
    ],
    "note": "Later version should distinguish calendar days vs trading days."
  },
  "anchor_selection_rules": {
    "preferred": [
      "absolute major low",
      "absolute major high",
      "earnings gap high/low",
      "major swing low/high",
      "ATH",
      "post-capitulation low",
      "post-breakout retest low"
    ],
    "bad_anchors": [
      "random intraday points",
      "emotionally chosen prices",
      "minor noise pivots",
      "post-hoc anchors selected only because they fit"
    ],
    "anchor_quality_score_inputs": [
      "market recognition",
      "volume significance",
      "event significance",
      "multi-timeframe visibility",
      "subsequent price reaction"
    ]
  },
  "resonance_score_v0": {
    "components": {
      "gann_time_proximity": 0.25,
      "gann_price_proximity": 0.25,
      "anchor_quality": 0.15,
      "multi_anchor_cluster": 0.15,
      "price_action_confirmation": 0.2
    },
    "interpretation": {
      "80_100": "high resonance action window",
      "60_79": "watch/partial action",
      "40_59": "incomplete setup",
      "0_39": "weak/no setup"
    }
  },
